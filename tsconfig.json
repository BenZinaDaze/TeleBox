{
  "compilerOptions": {
    "module": "NodeNext",
    "target": "es2020",
    "lib": ["dom", "es7", "ES2019", "ES2020"],
    "sourceMap": false,
    "allowJs": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "NodeNext",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "paths": {
      "@utils/*": ["./src/utils/*"],
      "hook/*": ["./src/hook/*"]
    }
  },
  "exclude": ["node_modules", "dist", "temp", "temp/**/*"],
  "include": ["src/**/*", "plugins/**/*"]
}
